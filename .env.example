ML_SERVICE_HTTP_PORT=8083

ML_SERVICE_POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@postgres:5432/ml_service

ML_SERVICE_OPENAI_API_KEY=sk-your-key
ML_SERVICE_EMBEDDING_MODEL=text-embedding-3-small
ML_SERVICE_LLM_MODEL=gpt-4.1-nano

ML_SERVICE_TOP_K=5
ML_SERVICE_MIN_SCORE=0.35
ML_SERVICE_CHUNK_SIZE_TOKENS=800
ML_SERVICE_CHUNK_OVERLAP_TOKENS=150
ML_SERVICE_MAX_FILE_SIZE_BYTES=10485760

ML_SERVICE_LOG_LEVEL=info
